		{
			"name": "Usuario",
			"description": "Gerenciamento de usuarios do sistema.\n\n**POST /v1/usuarios e PUBLICO** (criacao de conta, sem autenticacao).\nDemais endpoints requerem autenticacao Bearer Token.",
			"item": [
				{
					"name": "Criar Usuario",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// Gera email e CPF unicos para evitar erro 422 (duplicidade) entre execucoes",
									"var ts = Date.now().toString().slice(-8);",
									"",
									"// Email unico baseado em timestamp",
									"var email = \"teste\" + ts + \"@email.com\";",
									"pm.collectionVariables.set(\"testEmail\", email);",
									"try { pm.environment.set(\"testEmail\", email); } catch(e) {}",
									"",
									"// Gera CPF valido algoritmicamente (com digitos verificadores corretos)",
									"function gerarCpf() {",
									"    var n = [];",
									"    for (var i = 0; i < 9; i++) n.push(Math.floor(Math.random() * 9));",
									"    var d1 = 0;",
									"    for (var i = 0; i < 9; i++) d1 += n[i] * (10 - i);",
									"    d1 = 11 - (d1 % 11); if (d1 >= 10) d1 = 0; n.push(d1);",
									"    var d2 = 0;",
									"    for (var i = 0; i < 10; i++) d2 += n[i] * (11 - i);",
									"    d2 = 11 - (d2 % 11); if (d2 >= 10) d2 = 0; n.push(d2);",
									"    return n.join(\"\");",
									"}",
									"var cpf = gerarCpf();",
									"pm.collectionVariables.set(\"testCpf\", cpf);",
									"try { pm.environment.set(\"testCpf\", cpf); } catch(e) {}",
									"console.log(\"Gerado -> Email: \" + email + \", CPF: \" + cpf);"
