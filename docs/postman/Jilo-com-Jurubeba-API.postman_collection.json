	"event": [
		{
			"listen": "prerequest",
			"script": {
				"exec": [
					"// Auto-login: se o token estiver vazio e a request exigir auth, faz login",
					"var token = pm.variables.get(\"token\");",
					"if (!token && pm.request.auth && pm.request.auth.type === \"bearer\") {",
					"    pm.sendRequest({",
					"        url: pm.variables.get(\"base_url\") + \"/auth/login\",",
					"        method: \"POST\",",
					"        header: { \"Content-Type\": \"application/json\" },",
					"        body: {",
					"            mode: \"raw\",",
					"            raw: JSON.stringify({ email: \"admin@jilocomjurubeba.com\", senha: \"admin123\" })",
					"        }",
					"    }, function (err, res) {",
					"        if (!err && res.code === 200) {",
					"            var t = res.json().token;",
					"            pm.collectionVariables.set(\"token\", t);",
					"            try { pm.environment.set(\"token\", t); } catch(e) {}",
					"            console.log(\"Auto-login: token JWT obtido com sucesso\");",
					"        } else {",
					"            console.log(\"Auto-login falhou: \" + (err || res.status));",
					"        }",
					"    });",
					"}"
				],
				"type": "text/javascript"
			}
		}
	],
